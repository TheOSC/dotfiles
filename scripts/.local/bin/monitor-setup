#!/usr/bin/env bash
# Detect connected monitors and apply appropriate profile

DOCKED=$(hyprctl monitors | grep -c "DP-")

if [[ "$DOCKED" -ge 2 ]]; then
    # Docked — Dell portrait left, laptop center, Samsung TV above
    hyprctl eval "hl.monitor({ output = 'DP-4', mode = '1920x1080@60', position = '-1080x0', scale = 1, transform = 3 })"
    hyprctl eval "hl.monitor({ output = 'eDP-1', mode = '1920x1080@60', position = '0x0', scale = 1 })"
    hyprctl eval "hl.monitor({ output = 'DP-6', mode = '3840x2160@30', position = '0x-2160', scale = 1 })"
else
    # Undocked — laptop only
    hyprctl eval "hl.monitor({ output = 'eDP-1', mode = '1920x1080@60', position = '0x0', scale = 1 })"
fi
