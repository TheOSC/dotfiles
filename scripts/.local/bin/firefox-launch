#!/bin/bash
# firefox-launch — graceful shutdown + corruption recovery wrapper
PROFILE_DIR=$(find ~/.config/mozilla/firefox -maxdepth 1 -name "*.default-release" 2>/dev/null | head -1)

# If Firefox is already running, just open a new window
if pgrep -x firefox > /dev/null; then
    exec /usr/bin/firefox --new-window "$@"
    exit
fi

# Clear lock files
if [ -n "$PROFILE_DIR" ]; then
    rm -f "$PROFILE_DIR/lock" "$PROFILE_DIR/.parentlock"
fi

# If sessionstore shows signs of corruption, back it up
if [ -n "$PROFILE_DIR" ] && [ -f "$PROFILE_DIR/sessionstore-backups/recovery.jsonlz4" ]; then
    CRASHES=$(cat "$PROFILE_DIR/crashes/events/"* 2>/dev/null | wc -l)
    if [ "$CRASHES" -gt 0 ] || [ -f "$PROFILE_DIR/sessionstore.jsonlz4" ]; then
        mv "$PROFILE_DIR/sessionstore-backups/recovery.jsonlz4" "$PROFILE_DIR/sessionstore-backups/recovery.jsonlz4.bak" 2>/dev/null
        rm -f "$PROFILE_DIR/sessionstore.jsonlz4" 2>/dev/null
    fi
fi

exec /usr/bin/firefox "$@"
